{
	"name": "shorty-link",
	"version": "0.1.0",
	"description": "A single-deploy Cloudflare Workers URL shortener with Elysia, TanStack Start, Better Auth passkeys, and D1.",
	"type": "module",
	"private": false,
	"license": "MIT",
	"packageManager": "pnpm@10.32.1",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"typecheck": "tsc --noEmit",
		"test": "vitest run",
		"lint": "biome lint .",
		"lint:fix": "biome lint --write .",
		"format": "biome format .",
		"format:fix": "biome format --write .",
		"check": "biome check .",
		"check:fix": "biome check --write .",
		"check:fix:unsafe": "biome check --write --unsafe .",
		"ci:lint": "biome ci .",
		"verify": "pnpm ci:lint && pnpm typecheck && pnpm test && pnpm build",
		"deploy": "pnpm run build && wrangler deploy",
		"deploy:dry-run": "pnpm run build && wrangler deploy --dry-run",
		"cf-typegen": "wrangler types",
		"db:generate": "drizzle-kit generate",
		"db:migrate:local": "wrangler d1 migrations apply shorty-link --local",
		"db:migrate:remote": "wrangler d1 migrations apply shorty-link --remote",
		"secret:auth": "wrangler secret put BETTER_AUTH_SECRET",
		"setup:local": "pnpm install && pnpm cf-typegen && pnpm db:migrate:local",
		"docs:dev": "cd docs-site && pnpm install --ignore-workspace && pnpm dev --ignore-workspace",
		"build:docs": "cd docs-site && pnpm install --ignore-workspace && pnpm build --ignore-workspace",
		"docs:generate": "bash scripts/generate-docs.sh",
		"postman:generate": "bash scripts/generate-docs.sh"
	},
	"dependencies": {
		"@better-auth/api-key": "^1.6.5",
		"@better-auth/drizzle-adapter": "^1.6.5",
		"@better-auth/i18n": "^1.6.5",
		"@better-auth/passkey": "^1.6.5",
		"@elysiajs/eden": "^1.4.0",
		"@elysiajs/server-timing": "^1.4.0",
		"@elysiajs/swagger": "^1.3.1",
		"@logtape/logtape": "^2.0.5",
		"@sinclair/typebox": "^0.34.41",
		"@tanstack/react-form": "^1.25.0",
		"@tanstack/react-router": "^1.140.2",
		"@tanstack/react-start": "^1.140.2",
		"@tanstack/react-table": "^8.21.3",
		"better-auth": "^1.6.5",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"cmdk": "^1.1.1",
		"drizzle-orm": "^0.45.2",
		"elysia": "^1.4.13",
		"lucide-react": "^1.11.0",
		"nanoid": "^5.1.6",
		"openapi-types": "^12.1.3",
		"radix-ui": "^1.4.3",
		"react": "^19.2.0",
		"react-dom": "^19.2.0",
		"recharts": "3.8.0",
		"tailwind-merge": "^3.5.0"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.12",
		"@cloudflare/vite-plugin": "^1.35.0",
		"@tailwindcss/vite": "^4.2.4",
		"@types/node": "^25.6.0",
		"@types/react": "^19.2.2",
		"@types/react-dom": "^19.2.2",
		"@vitejs/plugin-react": "^6.0.1",
		"drizzle-kit": "^0.31.10",
		"openapi-to-postmanv2": "^6.0.1",
		"shadcn": "^4.5.0",
		"tailwindcss": "^4.2.4",
		"typescript": "^6.0.3",
		"vite": "^8.0.10",
		"vitest": "^4.1.5",
		"wrangler": "^4.87.0"
	},
	"pnpm": {
		"overrides": {
			"@esbuild-kit/core-utils>esbuild": "0.25.12"
		}
	}
}
