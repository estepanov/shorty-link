# Generate auth secret with: openssl rand -base64 32
BETTER_AUTH_SECRET=replace-with-a-32-byte-random-secret
BETTER_AUTH_ALLOWED_HOSTS=localhost:3000,localhost:8787,*.workers.dev
BETTER_AUTH_FALLBACK_URL=http://localhost:3000
PASSKEY_RP_NAME=Shorty Link
# PASSKEY_RP_ID=example.com

# Optional local-only browser automation login for Playwright/Chrome DevTools MCP.
# Never enable this in production.
AGENT_BROWSER_AUTH_ENABLED=false
# Generate auth secret with: openssl rand -base64 32
AGENT_BROWSER_AUTH_SECRET=replace-with-local-agent-secret
